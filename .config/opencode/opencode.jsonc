{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "skill": {
            "*": "allow"
        },
        "external_directory": {
            "/usr/lib/python*/**": "allow",
            "/usr/include/**": "allow",
            "~/git/**": "allow",
            "~/.local/lib/python*/**": "allow"
        }
    },
    "mcp": {
        "dida": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.dida365.com"
        }
    },
    "plugin": [
        "@franlol/opencode-md-table-formatter@0.0.3",
        "@mohak34/opencode-notifier@latest"
    ]
}
