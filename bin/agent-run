#!/usr/bin/env nu

# Run a oneshot task via OpenCode.
def main [
    --easy                          # use action-easy agent (default)
    --hard                          # use action-hard agent
    --continue (-c)                 # continue the last session
    ...prompt: string               # prompt
] {
    let agent = if $hard { "action-hard" } else { "action-easy" }
    let prompt = ($prompt | str join " ")
    let render = if (which glow | is-empty) { "cat" } else { "glow" }

    let opts = [
        # See also ~/.config/opencode/opencode.jsonc
        --agent $agent
        --title $"[oneshot] ($prompt)"
        ...(if $continue { ["--continue"] } else { [] })
    ]

    ^opencode run ...$opts $prompt | ^$render
}
